# Copy this file to `.env` and adjust as needed. NEVER commit your real `.env`.
# Every value is optional; the lab uses sensible defaults if a value is unset.

# --- Retrieval settings ---
RAG_CHUNK_SIZE=80
RAG_CHUNK_OVERLAP=20
RAG_TOP_K=3

# --- Privacy ---
# Hash-only audit logging is the default. Explicitly set true only when storing
# the raw query text is an intentional privacy decision.
RAG_LOG_QUERY_TEXT=false

# --- Optional: local model backend (NOT required for the core lab) ---
# If you extend the lab to use a local embedding server such as Ollama, point to
# it here. Everything stays on your machine; no data leaves the host. These are
# placeholders only — no real endpoints or secrets.
# OLLAMA_BASE_URL=http://localhost:11434
# EMBEDDING_MODEL=nomic-embed-text
